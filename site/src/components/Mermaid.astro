---
// Finds ```mermaid code
---

<style is:global>
  /* is:global is required here */
  .mermaid-root pre[data-language="mermaid"] {
    visibility: hidden;
    height: 0;
    margin: 0;
    padding: 0;
    overflow: hidden;
  }
</style>

<div class="mermaid-root">
  <slot />
</div>

<script>
  import mermaid from "mermaid";

  mermaid.initialize({
    startOnLoad: false,
    theme: "base",
    themeVariables: {
      background: "#f6f7f9",
      primaryColor: "#e4f0f1",
      primaryTextColor: "#12161d",
      primaryBorderColor: "#1e7a85",
      lineColor: "#5a6472",
      secondaryColor: "#ffffff",
      tertiaryColor: "#f6f7f9",
      fontFamily: "IBM Plex Mono, monospace",
      fontSize: "14px",
    },
  });

  async function renderDiagrams() {
    const blocks = document.querySelectorAll<HTMLElement>(
      '.mermaid-root pre[data-language="mermaid"]',
    );

    let i = 0;
    for (const pre of blocks) {
      const source = pre.textContent ?? "";

      const container = document.createElement("div");
      container.className = "mermaid-diagram not-prose my-8 overflow-x-auto";

      try {
        const { svg } = await mermaid.render(`mermaid-${i++}`, source);
        container.innerHTML = svg;
        pre.replaceWith(container);
      } catch (err) {
        // Leave the original code block in place if rendering fails
        console.error("Mermaid render failed:", err);
      }
    }
  }

  renderDiagrams();
</script>
