---
import { getCollection } from "astro:content";
import Layout from "../../../../layouts/Layout.astro";
import ProjectCard from "../../../../components/ProjectCard.astro";
import { projectMeta } from "../../../../data/projects";

const entries = (await getCollection("projects"))
  .map((e) => e.id.replace(/\.md$/, ""))
  .filter((slug) => projectMeta[slug]?.category === "client-work");
---

<Layout title="Client Work" path="development/projects/client-work">
  <section class="max-w-5xl mx-auto px-6 pt-16 pb-8">
    <h1 class="font-display text-3xl font-semibold tracking-tight text-ink">Client Work</h1>
    <p class="mt-3 max-w-xl text-muted leading-relaxed">
      Commercial projects — work built for paying clients, as opposed to self-initiated projects.
    </p>
  </section>
  <section class="max-w-5xl mx-auto px-6 pb-24">
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
      {entries.map((slug) => (
        <ProjectCard slug={slug} meta={projectMeta[slug]} />
      ))}
    </div>
  </section>
</Layout>
