---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import DocCard from "../../components/DocCard.astro";
import { extractDocMeta } from "../../lib/doc_meta";

const order = ["skills", "pentesting"];

const entries = await getCollection("osint");
const bySlug = new Map(entries.map((e) => [e.id.replace(/\.md$/, ""), e]));
const cards = order
  .map((slug) => bySlug.get(slug))
  .filter((e) => e !== undefined)
  .map((e) => ({ slug: e.id.replace(/\.md$/, ""), ...extractDocMeta(e.body ?? "") }));

const casesEntries = await getCollection("osintCases");
const casesMeta = casesEntries[0] ? extractDocMeta(casesEntries[0].body ?? "") : null;
---

<Layout title="OSINT" path="osint">
  <section class="max-w-5xl mx-auto px-6 pt-16 pb-8">
    <h1 class="font-display text-3xl font-semibold tracking-tight text-ink">OSINT</h1>
    <p class="mt-3 max-w-xl text-muted leading-relaxed">
      Open-source intelligence work — standalone from the tooling I build. Skills, techniques,
      and (over time) real case write-ups.
    </p>
  </section>
  <section class="max-w-5xl mx-auto px-6 pb-24">
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
      {cards.map((c) => (
        <DocCard href={`/osint/${c.slug}`} title={c.title} oneLiner={c.oneLiner} />
      ))}
      {casesMeta && (
        <DocCard href="/osint/cases" title={casesMeta.title} oneLiner={casesMeta.oneLiner} />
      )}
    </div>
  </section>
</Layout>
